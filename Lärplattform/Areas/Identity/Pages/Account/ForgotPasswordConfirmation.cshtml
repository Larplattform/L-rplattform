@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Forgot password confirmation";
    Layout = "~/Pages/Shared/Login.cshtml";
}


<form id="account" method="post">

      
 
    <a asp-page="/Account/Login" class="back position-absolute start-0 top-0 ps-5 pb-3 text-decoration-none ">Back</a>
    <h1 class=" mb-4  fw-bold">Forgot Password Conformation </h1>


   
    
    <div class=" mb-3">
        <p>
            Please check your email to reset your password.
        </p>
    </div>
    
</form>
