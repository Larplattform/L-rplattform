    @if (Model.Schedules != null && Model.Schedules.Count > 0)
    {
        <div class="d-flex flex-column align-items-center">
            <table class="table table-bordered table-striped bg-white shadow-sm rounded w-75">
                <thead class="thead-dark">
                    <tr>
                        <th scope="col">Start</th>
                        <th scope="col">End</th>
                        <th scope="col">Subject</th>
                         <th scope="col">TeacherName</th>
                        <th scope="col">Location</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.Schedules)
                    {
                        <tr>
                            <td>@entry.StartDate.ToString("t")</td>
                            <td>@entry.EndDate.ToString("HH:mm")</td>
                            <td>@entry.Course.SubjectName</td>
                              <td>@entry.TeacherName</td>
                            <td>@entry.Location</td>
                        </tr>
                    }
                </tbody>
            </table>

            <nav aria-label="Page navigation example" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Schedule" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@(Model.PageSize)">Previous</a>
                    </li>
                    <li class="page-item active">
                        <span class="page-link">@Model.PageNumber</span>
                    </li>

                    <li class="page-item @(Model.Schedules.Count < Model.PageSize ? "disabled" : "")">
                        <a class="page-link" asp-page="./Schedule" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@(Model.PageSize)">Next</a>
                    </li>
                </ul>
            </nav>

          
            
        </div>
    }
    else
    {
        <div class="d-flex justify-content-center">
            <p class="text-white">No schedules available.</p>
        </div>
    }

    