@page "{id:int}"
@model Lärplattform.Pages.Teacher.EditCourseModel
@{
    Layout = "~/Pages/Shared/Dashboard.cshtml";
}
<div id="content" style="background-color:#3F6E2F">

    <div id="Img-Dashboard" class="rounded shadow-sm mb-4 d-flex align-items-center">
        <div class="pl-5">
            <h1 class="text-dark font-weight-bold">Welcome Teacher! </h1>
           
        </div>
    </div>



    <div class="container mt-5">
        <div class=" row justify-content-center ">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Edit Course</h3>
                    </div>
                    <div class="card-body">
       
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="form-group mb-3">
                                <label asp-for="NewCourse.SubjectName" class="form-label">Subject Name</label>
                                <input asp-for="NewCourse.SubjectName" class="form-control" placeholder="e.g. Matematik 101" />
                                <span asp-validation-for="NewCourse.SubjectName" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="NewCourse.TotalMarks" class="form-label">Total Marks</label>
                                <input asp-for="NewCourse.TotalMarks" class="form-control" type="number" />
                                <span asp-validation-for="NewCourse.TotalMarks" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="NewCourse.ClassName" class="form-label">Class Name</label>
                                <input asp-for="NewCourse.ClassName" class="form-control" placeholder="e.g. MatteA" />
                                <span asp-validation-for="NewCourse.ClassName" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="NewCourse.Url" class="form-label">Url</label>
                                <input asp-for="NewCourse.Url" class="form-control" placeholder="e.g. Matte A jpeg" />
                                <span asp-validation-for="NewCourse.Url" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="NewCourse.StartDate" class="form-label">Start Date</label>
                                <input asp-for="NewCourse.StartDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                                <span asp-validation-for="NewCourse.StartDate" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label class="form-label">Duration</label>
                                <select name="Duration" class="form-control">
                                    <option value="1">1 months</option>
                                    <option value="2">2 months</option>
                                    <option value="3">3 months</option>
                                </select>
                            </div>
                            <div class="form-group mb-3">
                   
                                <input type="hidden" asp-for="NewCourse.TeacherID" class="form-control" />
                                <span asp-validation-for="NewCourse.TeacherID" class="text-danger"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success">Update Course</button>
                                <button asp-page-handler="Delete"  class="btn btn-danger">Delete Course</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>