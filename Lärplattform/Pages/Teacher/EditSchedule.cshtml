@page
@model Lärplattform.Pages.Teacher.EditScheduleModel
@{
    Layout = "~/Pages/Shared/Dashboard.cshtml";
}

<div id="content" style="background-color:#3F6E2F">

    <div id="Img-Dashboard" class="rounded shadow-sm mb-4 d-flex align-items-center">
        <div class="pl-5">
            <h1 class="text-dark font-weight-bold">Welcome Teacher! </h1>
           
        </div>
    </div>

    <div class="container mt-5">
        <div class=" row justify-content-center ">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Edit Schedule</h3>
                    </div>
                    <div class="card-body">
       
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <label asp-for="UpdateSchedule.CourseID" class="form-label">Course</label>
                            <select asp-for="UpdateSchedule.CourseID" class="form-control" asp-items="Model.CourseSelectList")">
                                <option value="">-- Select Course --</option>
                                
                            </select>
                            <div class="form-group mb-3">
                                <label asp-for="UpdateSchedule.StartDate" class="form-label">Start Date</label>
                                <input asp-for="UpdateSchedule.StartDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                                <span asp-validation-for="UpdateSchedule.StartDate" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label class="form-label">Duration</label>
                                <select name="Duration" class="form-control">
                                    <option value="1">1 hour</option>
                                    <option value="2">2 hours</option>
                                    <option value="3">3 hours</option>
                                </select>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="UpdateSchedule.Location" class="form-label">Location</label>
                                <select asp-for="UpdateSchedule.Location" class="form-control" asp-items="Model.Location">
                                    <option value="">-- Select Location --</option>
                                  
                                </select>
                                <span asp-validation-for="UpdateSchedule.Location" class="text-danger"></span>
                            </div>
                            

                           
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success">Update Schedule</button>
                                <button asp-page-handler="Delete" asp-route-ScheduleID="@Model.ScheduleID" class="btn btn-danger">Delete Schedule</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
