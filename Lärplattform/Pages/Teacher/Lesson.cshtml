@page
@model Lärplattform.Pages.Teacher.LessonModel
@{
    Layout = "~/Pages/Shared/Dashboard.cshtml";
}


<div id="content" style="background-color:#3F6E2F">

    <div id="Img-Dashboard" class="rounded shadow-sm mb-4 d-flex align-items-center">
        <div class="pl-5">
            <h1 class="text-dark font-weight-bold">Welcome Teacher! </h1>
            <p class="text-muted mb-0 small">
                Courses Overall @Model.Lessons.Count lessons found for this course.
            </p>
           
        </div>
    </div>
    <div class="row justify-content-center">
    @if(Model.Lessons != null && Model.Lessons.Any())
    {
            @foreach (var lesson in Model.Lessons)
            {
               
                <div class="col-12 col-md-6 col-lg-4 mb-3">
                <div class="card h-100 border-0 shadow-sm" >

                <div class=" card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-2">
                 <h5 class="card-title text-success font-weight-bold mb-0">@lesson.Title</h5>
                 <span class="badge badge-light border text-muted">ID: @lesson.LessonID</span>
                            </div>

                 <p class="card-text text-secondary small mb-3">@lesson.Description</p>
                      
                 <div class="mt-auto pt-3 border-top">
                     <p class="text-dark small font-italic" style="line-height:1.4;"></p>
                     <i class="fa fa-book-open mr-1"></i> @lesson.Content

                    

                 </div>
                        </div>
                    </div>
                </div>



            }

        }
        else
        {
            <div class="alert alert-info" role="alert">
                No lessons found for this course.
            </div>

            
        }

    </div>
</div>
