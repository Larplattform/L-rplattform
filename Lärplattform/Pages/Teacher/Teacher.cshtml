@page
@model Lärplattform.Pages.Teacher.TeacherModel
@{
    Layout = "~/Pages/Shared/Dashboard.cshtml";
}
 
<div id="content" style="background-color:#3F6E2F"> 
    <div id="Img-Dashboard" class="rounded shadow-sm mb-4 d-flex align-items-center">
        <div class="pl-5">
            <h1 class="text-dark font-weight-bold">Welcome Teacher! </h1>
           
        </div>
    </div>


<div id="courseCarousel" class="carousel slide" data-ride="false">
    <div class="carousel-inner">
        @{
            var first = true;
        }
        @foreach (var course in Model.Courses)
        {
            <div class="carousel-item @(first ? "active" : "")">
                <div class="d-flex justify-content-center">
                    <div class="card border-0 shadow-lg mb-4" style="border-radius: 15px; overflow: hidden; width: 350px;">
                            <img src="@(string.IsNullOrEmpty(course.Url) ? Url.Content("~/Math.jpg") : course.Url)" class="card-img-top" alt="Course Image" style="height: 180px; object-fit: cover;">
                        <div class="card-body bg-white p-4">
                            <h4 class="font-weight-bold mb-1 text-dark">@course.SubjectName</h4>
                            <p class="text-muted small">@course.ClassName</p>
                            <div class="d-flex align-items-center mt-4 pt-3 border-top">
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mr-3" style="width: 45px; height: 45px; border: 1px solid #eee;">
                                    <i class="far fa-user text-muted"></i>
                                </div>
                                <a href="#" class="text-dark font-weight-bold text-decoration-none">View students</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            first = false;
        }

    </div>

   <a class="carousel-control-prev" href="#courseCarousel" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon bg-dark rounded-circle" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
    </a>
    <a class="carousel-control-next" href="#courseCarousel" role="button" data-slide="next">
        <span class="carousel-control-next-icon bg-dark rounded-circle" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
    </a>

    <div class="text-center mt-4 pb-5">
        <a class="btn btn-primary px-5 py-2 shadow-sm font-weight-bold rounded-pill" asp-page="/Teacher/CreateCourse">
            <i class="fas fa-plus mr-2"></i> Add Course
        </a>
        </div>
</div>

</div>
  
  
 