@page
@model Lärplattform.Pages.Teacher.CreateScheduleModel
@{
    Layout = "~/Pages/Shared/Dashboard.cshtml";
}

<div id="content" style="background-color:#3F6E2F">

    <div id="Img-Dashboard" class="rounded shadow-sm mb-4 d-flex align-items-center">
        <div class="pl-5">
            <h1 class="text-dark font-weight-bold">Welcome Teacher! </h1>
           
        </div>
    </div>

    <div class="container mt-5">
        <div class=" row justify-content-center ">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Create New Schedule</h3>
                    </div>
                    <div class="card-body">
       
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <label asp-for="Schedule.CourseID" class="form-label">Course</label>
                            <select asp-for="Schedule.CourseID" class="form-control" asp-items="Model.Courses" )">
                                <option value="">-- Select Course --</option>
                                
                            </select>
                            <div class="form-group mb-3">
                                <label asp-for="Schedule.StartDate" class="form-label">Start Date</label>
                                <input asp-for="Schedule.StartDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                                <span asp-validation-for="Schedule.StartDate" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="Schedule.EndDate" class="form-label">End Date</label>
                                <input asp-for="Schedule.EndDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                                <span asp-validation-for="Schedule.EndDate" class="text-danger"></span>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Schedule.Location" class="form-label">Location</label>
                                <select asp-for="Schedule.Location" class="form-control" asp-items="Model.Location">
                                    <option value="">-- Select Location --</option>
                                  
                                </select>
                                <span asp-validation-for="Schedule.Location" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                   
                                <input type="hidden" asp-for="Schedule.CourseID" class="form-control" />
                                <span asp-validation-for="Schedule.CourseID" class="text-danger"></span>
                            </div>
                           
                            <div class="form-group mb-3">
                   
                                <input type="hidden" asp-for="Schedule.TeacherID" class="form-control" />
                                <span asp-validation-for="Schedule.TeacherID" class="text-danger"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success">Create Schedule</button>
                                <a asp-page="/Teacher/Schedule" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
