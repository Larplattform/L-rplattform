@page
@model Lärplattform.Pages.Teacher.SubmissionsModel
@{
    Layout = "~/Pages/Shared/Dashboard.cshtml";
}

<div id="content" style="background-color:#3F6E2F">

    <div id="Img-Dashboard" class="rounded shadow-sm mb-4 d-flex  align-items-center justify-content-between  p-4">
        <div class="pl-3">
            <h1 class="text-dark font-weight-bold">Welcome Teacher! </h1>
            <p class="text-muted mb-0 small">
                <strong>Courses Overall:</strong> @Model.Submission.Count Submissions found for this assigment.
            </p>
           
        </div>
      

    </div>
    <div class="row justify-content-center">
        @if (Model.Submission != null && Model.Submission.Any())
        {
            @foreach (var submission in Model.Submission)
            {
               
                <div class="col-12 col-md-6 col-lg-8 mb-3">
                    <div class="card h-100 border-0 shadow-sm">

                        <div class=" card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-success font-weight-bold mb-0">@submission.Content</h5>
                                <span class="badge badge-light border text-muted">StudentName: @submission.StudentName</span>
                            </div>

                            <p class="card-text text-secondary small mb-3"> Feedback : @submission.Feedback</p>
                            <p class="card-text text-secondary small mb-3">Grade @submission.Grade</p>
                      
                            <div class="mt-auto pt-3 border-top">
                                <p class="text-dark small font-italic" style="line-height:1.4;"></p>
                                <i class="fa fa-book-open mr-1"></i> AssigmentName @submission.AssigmentTitle

                                

                            </div>
                            <div class="d-flex justify-content-end">
                                <a class="btn btn-primary px-5 py-2 shadow-sm font-weight-bold rounded-pill" asp-page="/Teacher/EditSubmission" asp-route-Submissionid="@submission.SubmissionID">
                                    <i class="fas fa-plus mr-2"></i> Edit submission
                                </a>
                            </div>

                         
                        </div>
                    </div>
                </div>

               

            }
          

        }
        else
        {
            <div class="alert alert-info" role="alert">
                No submission found for this assigment.
            </div>
          
            
        }

    </div>
</div>

